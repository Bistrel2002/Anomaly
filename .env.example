# PostgreSQL
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name

# FastAPI (update host/port if needed)
DATABASE_URL=postgresql://your_db_user:your_db_password@db:5432/your_db_name

# Grafana
GF_ADMIN_USER=your_grafana_user
GF_ADMIN_PASSWORD=your_grafana_password

# HashiCorp Vault
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=your_vault_token_here

# AWS S3 (for secure backups)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=eu-west-1
S3_BUCKET_NAME=your-bucket-name

# HashiCorp Vault
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

# MinIO / S3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=anomaly-backups
AWS_ENDPOINT_URL=http://minio:9000
